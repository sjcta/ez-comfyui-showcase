/* ── ComfyUI Web v3.8 — Crypto-Wallet · Dark OLED · Bento Box Grid ── */
*{margin:0;padding:0;box-sizing:border-box}

@import url('https://fonts.googleapis.com/css2?family=Fira+Sans:wght@400;500;600;700&family=Fira+Code:wght@400;500;600&display=swap');

:root {
  /* ── Background (OLED) ── */
  --bg-deep:     #000000;
  --bg-base:     #0A0A0F;
  --bg-elevated: #111118;
  --bg-card:     #1A1A28;
  --bg-glass:    rgba(255,255,255,0.03);

  /* ── Accent (Crypto Gold + Purple) ── */
  --accent:      #F59E0B;
  --accent-dim:  #D97706;
  --accent-glow: rgba(245,158,11,0.25);
  --purple:      #8B5CF6;
  --purple-dim:  #7C3AED;
  --purple-glow: rgba(139,92,246,0.25);

  /* ── Text ── */
  --text:        #F1F5F9;
  --text-secondary: #94A3B8;
  --dim:         #64748B;

  /* ── Semantic ── */
  --green:       #22C55E;
  --red:         #EF4444;
  --orange:      #F59E0B;
  --yellow:      #EAB308;
  --blue:        #3B82F6;

  /* ── Border ── */
  --border:       rgba(255,255,255,0.06);
  --border-hover: rgba(255,255,255,0.12);
  --border-accent: rgba(245,158,11,0.3);
  --border-purple: rgba(139,92,246,0.3);

  /* ── Font ── */
  --font-sans: 'Fira Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  --font-mono: 'Fira Code', 'SF Mono', 'Monaco', 'Cascadia Code', monospace;

  /* ── Radius / Shadow / Space ── */
  --radius:       8px;
  --radius-sm:    6px;
  --radius-lg:    12px;
  --radius-xl:    16px;
  --radius-glass: 14px;

  --shadow-sm:   0 1px 3px rgba(0,0,0,0.5);
  --shadow-md:   0 4px 16px rgba(0,0,0,0.6);
  --shadow-lg:   0 8px 40px rgba(0,0,0,0.7);
  --shadow-glass: 0 4px 20px rgba(0,0,0,0.4);

  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 32px;

  --titlebar-h: 38px;
}

body {
  background: var(--bg-deep);
  color: var(--text);
  font-family: var(--font-sans);
  font-size: 13px;
  line-height: 1.45;
  height: 100vh;
  height: calc(var(--vh, 1vh) * 100);
  height: 100dvh;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
  display: flex;
  flex-direction: column;
  overscroll-behavior: none;
}

a { color: var(--accent); text-decoration: none; }

/* ═══ Keyframes — Card Entrance ═══ */
@keyframes cardIn {
  from { opacity: 0; transform: translateY(12px) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes cryptoGlow {
  0%, 100% { box-shadow: 0 0 18px rgba(245,158,11,0.2); }
  50% { box-shadow: 0 0 28px rgba(139,92,246,0.25); }
}

@keyframes spin { to { transform: rotate(360deg); } }

@keyframes dot-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

@keyframes led-blink { 0%,100%{ opacity:1 } 50%{ opacity:.3 } }

@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}

@keyframes toastIn { from { opacity: 0; transform: translateY(-80px); } to { opacity: 1; transform: translateY(0); } }
@keyframes toastOut { from { opacity: 1; } to { opacity: 0; transform: translateY(-60px); } }

@keyframes gradShift {
  0% { background-position: 0% 50%, 50% 0%, 100% 50%; }
  33% { background-position: 50% 0%, 100% 50%, 50% 100%; }
  66% { background-position: 100% 50%, 50% 100%, 0% 50%; }
  100% { background-position: 0% 50%, 50% 0%, 100% 50%; }
}

@keyframes glowShift {
  0%, 100% { box-shadow: 0 0 18px rgba(245,158,11,.2), 0 0 45px rgba(245,158,11,.08); }
  25% { box-shadow: 0 0 28px rgba(245,158,11,.4), 0 0 70px rgba(245,158,11,.18); }
  50% { box-shadow: 0 0 18px rgba(139,92,246,.2), 0 0 45px rgba(139,92,246,.08); }
  75% { box-shadow: 0 0 28px rgba(139,92,246,.4), 0 0 70px rgba(139,92,246,.18); }
}

/* ═══ Glass Card ═══ */
.glass-card {
  background: var(--bg-glass);
  backdrop-filter: blur(12px) saturate(1.1);
  -webkit-backdrop-filter: blur(12px) saturate(1.1);
  border: 1px solid var(--border);
  border-radius: var(--radius-glass);
  box-shadow: var(--shadow-glass);
}
.glass-card:hover {
  border-color: var(--border-hover);
  box-shadow: var(--shadow-md);
}

/* ═══ 标题栏 ═══ */

.titlebar {
  height: var(--titlebar-h);
  background: var(--bg-base);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 16px;
  flex-shrink: 0;
}

.titlebar .logo { font-size: 14px; font-weight: 700; white-space: nowrap; }
.titlebar .logo span { font-size: 16px; margin-right: 4px; }
.titlebar .logo {
  background: linear-gradient(135deg, #F59E0B, #8B5CF6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.titlebar-right { margin-left: auto; font-size: 11px; color: var(--dim); display: flex; align-items: center; gap: 8px; }

.tb-add-btn {
  appearance: none; -webkit-appearance: none;
  display: flex; align-items: center; gap: 4px;
  padding: 4px 10px;
  border: 1px dashed var(--dim);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--dim);
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  transition: all .15s;
  font-family: var(--font-sans);
}

.tb-add-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(245,158,11,.06);
}

.tb-add-btn .tb-add-icon {
  font-size: 14px;
  line-height: 1;
}

/* ═══ 功能区 - Bento Box Grid ═══ */

.workspace { flex: 1; display: flex; min-height: 0; overflow: hidden; }

/* --- 左列：Workflows + 出图 (Glassmorphism, Bento left) --- */

.col-left {
  width: 30%; min-width: 280px; max-width: 50%;
  background: var(--bg-elevated);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column; flex-shrink: 0;
  min-height: 0;
}

.resize-handle {
  width: 5px;
  cursor: col-resize;
  background: var(--border);
  flex-shrink: 0;
  position: relative;
  z-index: 10;
  transition: background .15s;
}

.resize-handle:hover, .resize-handle.active {
  background: var(--accent);
}

.col-header {
  padding: 8px 12px 6px;
  font-size: 11px; font-weight: 600;
  color: var(--text-secondary);
  text-transform: uppercase; letter-spacing: .5px;
  display: flex; align-items: center; gap: 6px; flex-shrink: 0;
  flex-wrap: nowrap;
  min-width: 0;
  white-space: nowrap;
}

.ch-count { font-weight: 400; opacity: .6; }

/* ── Workflow Tabs ── */
.wf-tabs {
  display: flex;
  gap: 4px;
  padding: 6px 12px 8px;
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
}
.wf-tabs::-webkit-scrollbar { display: none; }
.wf-tab {
  flex-shrink: 0;
  padding: 3px 10px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-elevated);
  color: var(--dim);
  font-size: 11px;
  cursor: pointer;
  transition: all .15s;
  white-space: nowrap;
}
.wf-tab:hover { border-color: var(--accent); color: var(--text); }
.wf-tab.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.wf-tab-i2i.active { background: rgba(139,92,246,.35); color: var(--purple); border-color: var(--purple); }
.wf-tab-t2i.active { background: rgba(245,158,11,.35); color: var(--accent); border-color: var(--accent); }
.wf-tab-t2v.active { background: rgba(245,158,11,.35); color: var(--orange); border-color: var(--orange); }
.wf-tab-i2v.active { background: rgba(245,158,11,.35); color: var(--orange); border-color: var(--orange); }
.wf-tab-cat.active { background: rgba(34,197,94,.35); color: var(--green); border-color: var(--green); }

.wf-grid .wf-card{flex:0 0 30%;scroll-snap-align:start;flex-shrink:0}
.wf-grid{display:flex;gap:12px;padding:0 20px 22px;scroll-padding-left:20px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch}

.wf-card {
  position: relative;
  border: 1px solid var(--border);
  border-radius: var(--radius-glass);
  overflow: hidden;
  cursor: pointer;
  transition: all .15s;
  background: var(--bg-glass);
  backdrop-filter: blur(12px) saturate(1.1);
  -webkit-backdrop-filter: blur(12px) saturate(1.1);
  box-shadow: var(--shadow-glass);
  display: flex;
  flex-direction: column;
}

.wf-card:hover {
  border-color: var(--border-hover);
  transform: translateY(-1px);
  box-shadow: var(--shadow-md);
}

.wf-card.active {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent), var(--shadow-md);
  background: rgba(245,158,11,.06);
}
.wf-card.active[data-cat="图生图"] { border-color: var(--purple); box-shadow: 0 0 0 1px var(--purple), var(--shadow-md); background: rgba(139,92,246,.06); }
.wf-card.active[data-cat="文生图"] { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent), var(--shadow-md); background: rgba(245,158,11,.06); }
.wf-card.active[data-cat="文生视频"] { border-color: var(--orange); box-shadow: 0 0 0 1px var(--orange), var(--shadow-md); background: rgba(245,158,11,.06); }
.wf-card.active[data-cat="图生视频"] { border-color: var(--orange); box-shadow: 0 0 0 1px var(--orange), var(--shadow-md); background: rgba(245,158,11,.06); }
.wf-card.active[data-cat="放大"] { border-color: var(--green); box-shadow: 0 0 0 1px var(--green), var(--shadow-md); background: rgba(34,197,94,.06); }

.wf-card-preview {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--bg-deep);
  overflow: hidden;
  position: relative;
}

.wf-card-preview img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  background: transparent;
}

.wf-card-preview .wf-card-icon {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  opacity: .15;
  color: var(--dim);
}

.wf-card-body {
  padding: 6px 8px 8px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  background: transparent;
}

.wf-card-name {
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
}
.wf-card-name-text {
  min-width: 0;
  word-break: break-all;
}

.wf-card-meta {
  font-size: 9px;
  color: var(--dim);
}

.wf-tag {
  font-size: 9px;
  font-weight: 600;
  padding: 1px 5px;
  border-radius: 3px;
  white-space: nowrap;
}

.wf-tag-t2i { background: rgba(245,158,11,.15); color: var(--accent); }
.wf-tag-i2i { background: rgba(139,92,246,.15); color: var(--purple); }
.wf-tag-i2v { background: rgba(245,158,11,.15); color: var(--orange); }
.wf-tag-t2v { background: rgba(245,158,11,.15); color: var(--orange); }
.wf-tag-cat { background: rgba(34,197,94,.2); color: var(--green); }
.wf-tag-res { background: rgba(0,0,0,.7); color: #fff; }

/* Upload card */
.wf-card.upload {
  border-style: dashed;
  border-color: var(--border);
  background: transparent;
}

.wf-card.upload:hover {
  border-color: var(--accent);
  background: rgba(245,158,11,.04);
}

.wf-card.upload .wf-card-preview {
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wf-card.upload .upload-icon {
  width: 28px;
  height: 28px;
  border: 2px solid var(--dim);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: var(--dim);
  transition: all .15s;
}

.wf-card.upload:hover .upload-icon {
  border-color: var(--accent);
  color: var(--accent);
}

.wf-card.upload .wf-card-name {
  text-align: center;
  color: var(--dim);
  font-weight: 500;
}

.wf-card.upload .wf-card-body {
  padding: 4px 8px 8px;
}

/* --- 右列：画廊 (Bento right) --- */

.col-center { flex: 1; display: flex; flex-direction: column; min-width: 0; min-height: 0; overflow-y: auto; }

/* ═══ Gallery Filters ═══ */
.gallery-filters {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 10px;
  flex-shrink: 0;
  background: var(--bg-base);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: none;
  flex-wrap: nowrap;
  width: 100%;
  min-width: 0;
}
.gallery-filters::-webkit-scrollbar { display: none; }
.gallery-filters select {
  padding: 3px 8px;
  border: 1px solid var(--border);
  border-radius: 4px;
  background: var(--bg-elevated);
  color: var(--text);
  font-size: 11px;
  outline: none;
  cursor: pointer;
  flex: 0 0 auto;
  width: auto;
  min-width: 70px;
  white-space: nowrap;
  appearance: auto;
}
.gallery-filters select:focus { color: var(--accent); }
.gf-sep {
  width: 1px;
  height: 14px;
  background: var(--border);
  flex-shrink: 0;
  margin: 0 6px;
}
.gf-clear {
  flex: 0 0 auto;
  padding: 2px 6px;
  border: none;
  background: transparent;
  color: var(--dim);
  font-size: 12px;
  cursor: pointer;
  opacity: 0.5;
  transition: opacity .15s;
}
.gf-clear:hover { opacity: 1; color: var(--red); }
.gf-search {
  margin-left: auto;
  padding: 3px 8px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--bg-deep);
  color: var(--text);
  font-size: 11px;
  width: 120px;
  max-width: 50%;
  flex-shrink: 0;
  outline: none;
}
.gf-search:focus { border-color: var(--accent); }
.gf-search::placeholder { color: var(--dim); font-size: 10px; }

/* ═══ 瀑布流 Grid (Bento masonry) ═══ */

.masonry {
  overflow: visible;
  padding: 14px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 14px;
  align-content: start;
  grid-auto-rows: max-content;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior-y: contain;
  touch-action: pan-y;
}

.masonry .gi {
  position: relative;
}

.masonry .gi-img {
  aspect-ratio: 1 / 1;
  background: var(--bg-deep);
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.masonry .gi-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.masonry .gi-img.lazy-img {
  background: var(--bg-deep);
  position: relative;
}

.masonry .gi-img.lazy-img img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.masonry-sentinel {
  height: 1px;
  width: 100%;
  margin-top: 4px;
}

/* Job cards in masonry: keep fixed aspect ratio */
.masonry .gi.job-card .gi-img {
  min-height: 65%;
}

@media (max-width: 600px) {
  .masonry { padding: 6px; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  .workspace { padding: 0 6px; }
  .col-center { padding: 0 6px; }
  .gallery-filters { padding: 4px 6px; }
  .col-header { padding: 6px 12px; }
}
/* Prevent iOS zoom on input focus */
@media (max-width: 600px) {
  input[type="text"],
  input[type="number"],
  textarea,
  select,
  .gf-search,
  .gf-input,
  #promptInput {
    font-size: 16px !important;
  }
}

/* ═══════════════════════════════════════════════════════════════════════
   卡片系统 (Glassmorphism)
   ═══════════════════════════════════════════════════════════════════════ */

.gi {
  position: relative;
  border-radius: var(--radius-glass);
  border: 1px solid var(--border);
  background: var(--bg-glass);
  backdrop-filter: blur(12px) saturate(1.1);
  -webkit-backdrop-filter: blur(12px) saturate(1.1);
  box-shadow: var(--shadow-glass);
  cursor: pointer;
  transition: border-color .15s, box-shadow .15s, transform .15s;
  overflow: hidden;
  animation: cardIn 0.35s ease both;
}

.gi-type-t2i { border-color: rgba(245,158,11,.4); }
.gi-type-i2i { border-color: rgba(139,92,246,.4); }
.gi-type-t2v { border-color: rgba(245,158,11,.4); }
.gi-type-i2v { border-color: rgba(245,158,11,.4); }
.gi-type-cat { border-color: rgba(34,197,94,.4); }
.gi-type-res { border-color: rgba(100,116,139,.4); }

.gi:hover {
  border-color: var(--border-hover);
  box-shadow: var(--shadow-md);
  transform: translateY(-1px);
}

.gi-type-t2i:hover { border-color: var(--accent) !important; box-shadow: var(--shadow-md); }
.gi-type-i2i:hover { border-color: var(--purple) !important; box-shadow: var(--shadow-md); }
.gi-type-t2v:hover { border-color: var(--orange) !important; box-shadow: var(--shadow-md); }
.gi-type-i2v:hover { border-color: var(--orange) !important; box-shadow: var(--shadow-md); }
.gi-type-cat:hover { border-color: var(--green) !important; box-shadow: var(--shadow-md); }
.gi-type-res:hover { border-color: var(--dim) !important; box-shadow: var(--shadow-md); }

/* 图片区域 — 固定 1:1 */
.gi-img {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--bg-deep);
  overflow: hidden;
}

.gi-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

/* Workflow 名标签 — 图片区左上角 */
.gi-wf-badge {
  position: absolute;
  top: 6px;
  left: 6px;
  max-width: 50%;
  padding: 2px 7px;
  border-radius: 4px;
  background: rgba(0,0,0,.7);
  color: var(--accent);
  font-size: 10px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  z-index: 4;
  backdrop-filter: blur(4px);
  pointer-events: none;
}
.gi-wf-badge > span { font-size: 9px; padding: 1px 5px; vertical-align: middle; margin-left: 4px; }
.gi-wf-badge > span:first-child { margin-left: 0; }
.gi-wf-badge > span:last-child { background: rgba(139,92,246,.3); color: var(--purple); }

/* 删除按钮 */
.gi-del {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: rgba(0, 0, 0, .7);
  color: var(--red);
  border: none;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 5;
  backdrop-filter: blur(4px);
  transition: background .15s;
}

.gi:hover .gi-del { display: flex; }
.gi.job-card.error .gi-del { display: flex; }
.gi.job-card.queued .gi-del,
.gi.job-card.generating .gi-del,
.gi.job-card.done .gi-del { display: flex; }
.gi-del:hover { background: var(--red); color: #fff; }

/* 放大按钮 */
.gi-zoom {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(0, 0, 0, .6);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, .2);
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 5;
  backdrop-filter: blur(4px);
  transition: background .15s, transform .15s;
}

.gi:hover .gi-zoom { display: flex; }
.gi-zoom:hover { background: var(--accent); transform: translate(-50%, -50%) scale(1.15); }

/* 类型角标 */
.gi-type-badge {
  position: absolute;
  top: 6px;
  left: 6px;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 10px;
  font-weight: 600;
  z-index: 4;
  backdrop-filter: blur(4px);
  pointer-events: none;
  opacity: 0;
  transition: opacity .2s;
}
.gi:hover .gi-type-badge { opacity: 1; }
.gi-type-badge.wf-tag-t2i { background: rgba(245,158,11,.8); color: #000; }
.gi-type-badge.wf-tag-i2i { background: rgba(139,92,246,.8); color: #fff; }
.gi-type-badge.wf-tag-t2v { background: rgba(245,158,11,.8); color: #000; }
.gi-type-badge.wf-tag-i2v { background: rgba(245,158,11,.8); color: #000; }
.gi-type-badge.wf-tag-cat { background: rgba(34,197,94,.8); color: #000; }
.gi-type-badge.wf-tag-res { background: rgba(0,0,0,.8); color: #fff; }

/* 标签行容器 */
.gi-tags-row {
  position: absolute;
  top: 6px;
  left: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 4;
  pointer-events: none;
}

/* gi-type-badge 在 gi-tags-row 内部时取消绝对定位 */
.gi-tags-row .gi-type-badge {
  position: static;
  pointer-events: auto;
}

/* 图片信息按钮区域 */
.gi-reuse {
  position: absolute;
  bottom: 6px;
  right: 6px;
  padding: 4px 10px;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 6px;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(6px);
  color: #fff;
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  opacity: 0;
  transition: opacity .2s, background .15s;
  z-index: 5;
  pointer-events: auto;
}
.gi:hover .gi-reuse { opacity: 1; }
.gi-reuse:hover { background: rgba(245,158,11,0.8); border-color: rgba(245,158,11,0.6); }

/* 文字区域 */
.gi-info {
  padding: 6px 8px 7px;
  border-top: 1px solid var(--border);
  position: relative;
}

.gi-progress-top {
  position: absolute;
  top: -1px;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--border);
  border-radius: 0;
  margin-bottom: 0;
}

.gi-progress-top .gi-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 0;
  transition: width .3s ease;
}

.gi-prompt {
  font-size: 11px;
  color: var(--text);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
  margin-bottom: 4px;
}

.gi-wf-label { font-size: 11px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }

.gi-meta {
  font-size: 10px;
  color: var(--dim);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.gi-meta-row {
  display: flex;
  flex-direction: row;
  gap: 20px;
  align-items: center;
  white-space: nowrap;
  line-height: 1.4;
}

/* ═══════════════════════════════════════════════════════════════════════
   出图中 / 错误 卡片
   ═══════════════════════════════════════════════════════════════════════ */

.gi.job-card { border-style: dashed; border-color: var(--yellow); cursor: default; }

.gi.job-card.generating { border-color: var(--accent); border-style: solid; }
.gi.job-card.error       { border-style: solid; border-color: var(--red); }
.gi.job-card.done        { border-style: solid; border-color: var(--green); }
.gi.job-card.preparing   { border-color: var(--yellow); }
.gi.job-card.dispatching  { border-color: var(--yellow); }
.gi.job-card.starting_comfyui { border-color: var(--yellow); }

.gi-detail {
  font-size: 10px;
  color: var(--accent);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  opacity: .85;
  margin-bottom: 2px;
}

.gi-progress-bar {
  width: 100%;
  height: 3px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 4px;
}

.gi-progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 2px;
  transition: width .3s ease;
}

/* 出图中占位 */
.gi-img.job-placeholder {
  aspect-ratio: unset;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: var(--dim);
  font-size: 12px;
}

.job-spinner {
  width: 28px; height: 28px;
  border: 3px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin .8s linear infinite;
}

.job-status-text { font-weight: 600; font-size: 11px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
.job-status-text.queued     { background: var(--accent); color: #000; font-size: 14px; padding: 4px 12px; border-radius: 6px; font-weight: 700; }
.job-status-text.preparing  { color: var(--yellow); }
.job-status-text.starting_comfyui { color: var(--yellow); }
.job-status-text.generating { color: var(--accent); }
.job-status-text.error      { color: var(--red); }
.job-status-text.downloading { color: var(--yellow); }

.job-err-badge {
  position: absolute;
  top: 6px; right: 6px;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px; font-weight: 600;
  background: rgba(0,0,0,.8);
  color: var(--red);
  z-index: 4;
}

/* 错误卡片中的重试按钮 */
.gi-retry-row {
  padding: 4px 0 2px;
}

.btn-retry {
  width: auto;
  padding: 5px 14px;
  border: 1px solid var(--red);
  border-radius: 4px;
  background: transparent;
  color: var(--red);
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  transition: all .15s;
}

.btn-retry:hover {
  background: var(--red);
  color: #fff;
}

/* ═══ 出图面板（左列内） ═══ */

.col-divider {
  height: 1px;
  background: var(--border);
  margin: 4px 12px;
  flex-shrink: 0;
}

.col-section-header {
  border-top: 1px solid var(--border);
  padding: 12px 12px 10px;
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  border-bottom: 1px solid var(--border);
  background: rgba(245,158,11,.06);
  letter-spacing: 0.5px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6px;
}

.gen-form { padding: 8px 14px 14px; display: flex; flex-direction: column; flex-shrink: 0; }

.gen-form > .fg { flex-shrink: 0; }
.gen-form > .adv-toggle { flex-shrink: 0; }
.gen-form > .gen-actions { flex-shrink: 0; }

.fg { margin-bottom: 10px; }
.fg label {
  display: block; font-size: 11px; font-weight: 500; color: var(--dim);
  margin-bottom: 3px; text-transform: uppercase; letter-spacing: .3px;
}
.fg label .node-tag { font-size: 10px; color: var(--dim); opacity: .5; text-transform: none; letter-spacing: 0; }
.fg-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }

input[type="text"], input[type="number"], textarea, select {
  width: 100%; background: var(--bg-deep); border: 1px solid var(--border);
  color: var(--text); border-radius: var(--radius-sm);
  padding: 7px 10px; font-size: 13px; font-family: var(--font-sans); transition: border-color .15s;
}
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(245,158,11,.12); }
textarea { min-height: 120px; resize: vertical; line-height: 1.5; }

/* ── 尺寸比例选择 ── */

.ratio-grid {
  display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
  margin-bottom: 6px;
}

.ratio-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px;
  padding: 6px 4px 4px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-deep);
  color: var(--dim);
  cursor: pointer;
  transition: all .15s;
  min-width: 0;
}

.ratio-btn:hover {
  border-color: var(--accent);
  color: var(--text);
  background: rgba(245,158,11,.06);
}

.ratio-btn.active {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(245,158,11,.1);
}

.ratio-shape {
  display: block;
  border: 1.5px solid currentColor;
  border-radius: 2px;
  flex-shrink: 0;
}

.ratio-label {
  font-size: 9px; font-weight: 600;
  white-space: nowrap;
}

.ratio-custom {
  display: flex; align-items: center; gap: 6px;
  font-size: 12px; color: var(--dim);
}

.ratio-custom input[type="number"] {
  flex: 1;
  min-width: 0;
  padding: 5px 8px;
  font-size: 12px;
  text-align: center;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--text);
}
select { cursor: pointer; }

.seed-group { display: flex; gap: 4px; align-items: stretch; }
.seed-group input { flex: 1; }
.seed-group .btn-dice {
  padding: 0 9px; background: var(--bg-deep); border: 1px solid var(--border);
  border-radius: var(--radius-sm); color: var(--text); cursor: pointer;
  font-size: 14px; transition: all .12s; display: flex; align-items: center;
}
.seed-group .btn-dice:hover { background: var(--border); }

.adv-toggle {
  display: flex; align-items: center; gap: 5px;
  padding: 10px 0; font-size: 12px; font-weight: 600; color: var(--dim);
  cursor: pointer; user-select: none; border: none; background: none;
  width: 100%; text-align: left;
  border-top: 1px dashed var(--border);
  margin-top: 8px;
}
.adv-toggle:hover { color: var(--text); }
.adv-toggle .arrow { transition: transform .2s; font-size: 10px; }
.adv-toggle.open .arrow { transform: rotate(90deg); }
.adv-body { overflow: hidden; max-height: 0; transition: max-height .25s ease; flex-shrink: 0; }
.adv-body.open { max-height: 3000px; }

.col-left-scroll {
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.gen-footer {
  padding: 10px 14px;
  border-top: 1px solid var(--border);
  background: var(--bg-elevated);
  flex-shrink: 0;
  display: flex;
  gap: 8px;
}
.gen-footer .btn-primary { flex: 1; }
.gen-toggle-mobile { display: none; }

.btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 5px; padding: 9px 18px; border: none; border-radius: var(--radius-sm);
  font-size: 13px; font-weight: 600; cursor: pointer; transition: all .15s; white-space: nowrap;
}
.btn svg, button svg { display: block; flex-shrink: 0; }
.btn-primary { background: var(--accent); color: #000; flex: 1; }
.btn-primary:hover { background: var(--accent-dim); color: #000; }
.btn-primary:disabled { opacity: .45; cursor: not-allowed; }

/* ═══ Node Management ═══ */
.node-pane { padding: 8px 16px 16px; }
.node-pane-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); margin-bottom: 8px; }
.node-pane-title { font-weight: 600; font-size: 13px; color: var(--text); }
.node-list { display: flex; flex-direction: column; gap: 8px; }
.node-card { border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 12px; background: var(--bg-deep); }
.node-card-header { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.node-card-title { font-weight: 600; font-size: 13px; color: var(--text); flex: 1; }
.node-card-actions { display: flex; gap: 4px; margin-left: auto; flex-shrink: 0; }
.node-card-addr { font-size: 11px; color: var(--dim); margin: 2px 0; }
.node-card-labels { display: flex; gap: 4px; margin: 2px 0; flex-wrap: wrap; }
.node-card-footer { margin-top: 6px; padding-top: 6px; border-top: 1px solid var(--border); display: flex; gap: 6px; }
.node-instance-row { display: flex; align-items: center; gap: 6px; padding: 3px 0; font-size: 12px; }
.node-instance-name { font-weight: 500; color: var(--text); min-width: 20px; }
.node-instance-port { color: var(--dim); font-size: 11px; }
.node-instance-status { font-size: 11px; color: var(--dim); min-width: 40px; }
.node-instance-queue { font-size: 10px; color: var(--accent); padding: 1px 5px; background: rgba(245,158,11,.1); border-radius: 8px; }
.node-instance-actions { display: flex; gap: 4px; margin-left: auto; flex-shrink: 0; }
.node-status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.dot-green { background: var(--green); box-shadow: 0 0 4px rgba(34,197,94,.4); }
.dot-yellow { background: var(--yellow); box-shadow: 0 0 4px rgba(234,179,8,.4); }
.dot-red { background: var(--red); box-shadow: 0 0 4px rgba(239,68,68,.4); }
.dot-orange { background: var(--orange); box-shadow: 0 0 4px rgba(245,158,11,.5); }
.dot-gray { background: #6b7280; }
.dot-blink { animation: dot-blink 1s ease-in-out infinite; }
.node-conn-tag { font-size: 11px; padding: 2px 10px; border-radius: 10px; font-weight: 600; border-width: 1.5px; border-style: solid; background: transparent; }
.conn-local { border-color: #6b7280; color: #9ca3af; }
.conn-ssh { border-color: var(--blue); color: #60a5fa; }
.conn-http { border-color: var(--yellow); color: var(--yellow); }

.ne-field { margin-bottom: 6px; font-size: 12px; }
#nodeEditModal .ne-field { display: flex; align-items: center; gap: 8px; }
.ne-field label { width: 80px; flex-shrink: 0; color: var(--dim); text-align: right; }
.ne-footer { display: flex; justify-content: flex-end; gap: 8px; padding: 10px 12px; border-top: 1px solid var(--border); }
.scan-result-row { padding: 4px 0; font-size: 12px; }
.scan-result-row label { display: flex; align-items: center; gap: 6px; cursor: pointer; }
.wf-overlay-tabs { display: flex; gap: 0; }
.wf-overlay-tabs .tab-btn { display: inline-flex; align-items: center; gap: 4px; padding: 6px 14px; border: none; background: transparent; color: var(--dim); font-size: 12px; cursor: pointer; border-bottom: 2px solid transparent; transition: all .15s; font-family: var(--font-sans); }
.wf-overlay-tabs .tab-btn:hover { color: var(--text); }
.wf-overlay-tabs .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

.btn-icon {
  width: 36px; height: 36px; padding: 0;
  background: var(--border); border: none; border-radius: var(--radius-sm);
  color: var(--text); cursor: pointer; font-size: 16px;
  display: flex; align-items: center; justify-content: center; transition: all .12s;
}
.btn-icon:hover { background: var(--border-hover); }

/* ═══ 状态栏 ═══ */

.statusbar {
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 5px 16px; gap: 12px; flex-shrink: 0;
  min-height: 32px;
}

.sb-vram { display: flex; align-items: center; gap: 8px; flex: 1; max-width: 480px; min-width: 200px; }
.sb-vram-label { font-size: 10px; font-weight: 600; color: var(--dim); text-transform: uppercase; letter-spacing: .5px; flex-shrink: 0; width: 38px; }
.sb-vram-track { flex: 1; height: 10px; background: var(--border); border-radius: 5px; overflow: hidden; position: relative; }
.sb-vram-fill { height: 100%; border-radius: 5px; transition: width .6s ease, background .3s; background: var(--green); min-width: 4px; }
.sb-vram-fill.busy { background: var(--orange); }
.sb-vram-fill.overload { background: var(--red); }
.sb-vram-segments { position: absolute; inset: 0; pointer-events: none; }
.sb-vram-seg { position: absolute; top: 0; bottom: 0; width: 1px; background: rgba(255,255,255,.08); }
.sb-vram-text { font-size: 11px; color: var(--text); font-variant-numeric: tabular-nums; white-space: nowrap; min-width: 80px; }

.sb-gpu { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--dim); font-variant-numeric: tabular-nums; flex-shrink: 0; }
.sb-sep { opacity: .3; }
.sb-metric { white-space: nowrap; }

.sb-spacer { flex: 1; }
.sb-services { display: flex; gap: 6px; flex-shrink: 0; }
.svc-btn {
  appearance: none; -webkit-appearance: none;
  display: flex; align-items: center; gap: 6px;
  padding: 4px 12px; border-radius: 6px;
  border: 1px solid var(--border);
  font-size: 11px; cursor: pointer; transition: all .15s;
  white-space: nowrap; user-select: none;
  background: var(--bg-deep);
  font-family: var(--font-sans);
  color: var(--text);
}
.svc-btn:hover { border-color: var(--dim); }
.svc-btn:active { transform: scale(.97); }
.svc-led {
  width: 8px; height: 8px; border-radius: 50%;
  transition: background .3s, box-shadow .3s;
  background: var(--red);
  box-shadow: 0 0 4px var(--red);
}
.svc-btn.on .svc-led { background: var(--green); box-shadow: 0 0 6px var(--green); }
.svc-btn.on { border-color: var(--green); background: rgba(34,197,94,.08); }
.svc-btn.on:hover { background: rgba(34,197,94,.15); }
.svc-btn.off .svc-led { background: var(--dim); box-shadow: none; }
.svc-btn.off { border-color: var(--border); background: var(--bg-deep); }
.svc-btn.off:hover { background: rgba(255,255,255,.03); }
.svc-btn.pending { border-color: var(--yellow); }
.svc-btn.pending .svc-led { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); animation: led-blink .8s ease-in-out infinite; }
.svc-label { font-weight: 600; }
.svc-state { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--dim); }
.svc-btn.on .svc-state { color: var(--green); }
.svc-btn.off .svc-state { color: var(--dim); }

/* Statusbar state tinting */
.statusbar[data-state="busy"] { background: rgba(245,158,11,.06); border-bottom-color: rgba(245,158,11,.3); }
.statusbar[data-state="overload"] { background: rgba(239,68,68,.08); border-bottom-color: var(--red); }

/* ═══ Lightbox ═══ */

.lightbox {
  position: fixed; inset: 0;
  background: rgba(0,0,0,.92); z-index: 1000;
  display: none; align-items: center; justify-content: center;
  padding: 40px; cursor: zoom-out; backdrop-filter: blur(8px);
}
.lightbox.open { display: flex; }
.lightbox img { max-width: 95vw; max-height: 90vh; border-radius: var(--radius); box-shadow: 0 0 40px rgba(0,0,0,.5); border: 1px solid rgba(245,158,11,.15); }

.lb-close {
  position: absolute; top: 16px; right: 20px;
  background: rgba(0,0,0,.55); border: 1px solid rgba(255,255,255,.25); color: #fff;
  font-size: 28px; width: 44px; height: 44px; border-radius: 50%;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background .15s;
}
.lb-close:hover { background: rgba(255,255,255,.3); }

.lb-download {
    position: fixed; top: 20px; right: 60px; z-index: 1002;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,.5); color: #fff; border: none;
    border-radius: 8px; cursor: pointer; text-decoration: none;
    transition: background .2s;
}
.lb-download:hover { background: rgba(255,255,255,.3); }

.lb-info {
  position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,.7); color: var(--dim);
  padding: 7px 18px; border-radius: 18px; font-size: 12px;
  white-space: nowrap; max-width: 90vw; overflow: hidden; text-overflow: ellipsis;
}

.lb-nav {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(0,0,0,.5); border: 1px solid rgba(255,255,255,.2); color: #fff;
  font-size: 32px; width: 48px; height: 48px; border-radius: 50%;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: background .15s; box-shadow: 0 2px 12px rgba(0,0,0,.4);
}
.lb-nav:hover { background: rgba(255,255,255,.25); }
.lb-prev { left: 16px; }
.lb-next { right: 16px; }

/* ═══ Scrollbar ═══ */

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--dim); }

/* ═══ 空状态 ═══ */

.empty-hint { column-span: all; text-align: center; padding: 50px 20px; color: var(--dim); }
.empty-hint .eh-icon { font-size: 42px; opacity: .2; margin-bottom: 8px; }

/* gen-form toggle */
.gen-arrow { display: none; font-size: 11px; opacity: 0.6; }
.col-section-header.clickable { user-select: none; }

/* ═══ 响应式 ═══ */

@media (max-width: 900px) {
  .workspace { flex-direction: column; overflow-y: auto; overflow-x: hidden; -webkit-overflow-scrolling: touch; }
  .col-left {
    width: 100% !important;
    min-width: 0 !important;
    max-width: none !important;
    max-height: none;
    border-right: none;
    border-bottom: 2px solid var(--accent);
    overflow: visible;
    flex-shrink: 0;
  }
  .col-center {
    flex: none;
    min-height: 60vh;
    overflow: visible;
  }
  .masonry { column-count: 2; overflow: visible; }
  .wf-grid { display: flex; gap: 8px; padding: 0 12px 8px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
  .wf-drop { display: none; }
  .wf-grid .wf-card { min-width: 100px; max-width: 120px; scroll-snap-align: start; flex-shrink: 0; }
  .col-divider { display: none; }
  .resize-handle { display: none; }
  .sb-vram { max-width: none; min-width: 120px; flex: 2; }
  .sb-gpu { display: none; }
  .svc-btn { padding: 3px 6px; font-size: 10px; gap: 4px; }
  .svc-state { display: none; }
  .gen-form { display: none; }
  .gen-form.mobile-open { display: flex; }
  .col-left-scroll {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
  }
  .gen-footer { display: none; }
  .gen-footer.mobile-open { display: flex; }
  .col-section-header.clickable { padding: 12px 12px; font-size: 14px; cursor: pointer; }
  .gen-arrow { display: inline; }
  .ratio-grid { grid-template-columns: repeat(7, 1fr); }
}

@media (max-width: 600px) {
  .gallery-filters { flex-wrap: wrap; gap: 4px; padding: 4px 6px; }
  .gallery-filters select { font-size: 13px !important; min-width: 60px; max-width: 45%; }
  .gf-search { width: 80px; max-width: 35%; font-size: 13px !important; }
}

@media (max-width: 600px) {
  .wf-dirs-add { flex-wrap: wrap; gap: 4px; }
  .wf-dir-input { flex: 1 1 100%; font-size: 13px !important; min-width: 0; }
  .wf-dir-add-confirm, .wf-dir-add-cancel { flex: 1; }
}

/* ═══ Workflow Management Overlay ═══ */

/* ═══ Toolbar buttons — unified V4 style ═══ */
.tb-log-btn,
.tb-wf-mgr-btn,
.wf-mgr-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: var(--radius);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  font-family: var(--font-sans);
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  color: var(--text-secondary);
  transition: all .15s;
}
.tb-log-btn:hover,
.tb-wf-mgr-btn:hover,
.wf-mgr-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(245,158,11,.06);
  box-shadow: 0 0 12px rgba(245,158,11,.1);
}

.wf-overlay {
  display: none; position: fixed; inset: 0; z-index: 1000;
  background: var(--bg-deep); overflow-y: auto;
}
.wf-overlay.open { display: block; }

.wf-overlay-inner { height: 100vh; overflow-y: auto;
  max-width: 1100px; margin: 0 auto; padding: 16px 20px;
}

.wf-overlay-header {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 14px; border-bottom: 1px solid var(--border); margin-bottom: 16px;
}

.wf-overlay-title {
  font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 8px;
}

.wf-overlay-count { font-size: 12px; color: var(--dim); font-weight: 400; }

.wf-overlay-close {
  background: none; border: 1px solid var(--border); color: var(--dim);
  width: 32px; height: 32px; border-radius: 50%; font-size: 16px;
  cursor: pointer; transition: all .15s; display: flex; align-items: center; justify-content: center;
}
.wf-overlay-close:hover { border-color: var(--red); color: var(--red); }

/* ═══ Workflow Manager Toolbar ═══ */
.wf-mgr-toolbar { display:flex; align-items:center; gap:10px; padding:8px 16px; border-bottom:1px solid var(--border); background:var(--bg-base); flex-wrap:wrap; }
.wf-mgr-filter-tabs { display:flex; gap:4px; flex-wrap:wrap; flex:1; }
.wf-mgr-filter-tab { padding:4px 10px; border-radius:14px; font-size:11px; cursor:pointer; border:1px solid var(--border); background:var(--bg-deep); color:var(--dim); transition:all .15s; white-space:nowrap; }
.wf-mgr-filter-tab:hover { border-color:var(--accent); color:var(--text); }
.wf-mgr-filter-tab.active { background:var(--accent); color:#000; border-color:var(--accent); }
.wf-mgr-filter-tab .count { opacity:.6; margin-left:3px; font-size:10px; }
.wf-mgr-sort { display:flex; align-items:center; gap:6px; flex-shrink:0; }
.wf-mgr-sort-label { font-size:11px; color:var(--dim); }
.wf-mgr-sort-select { padding:3px 6px; border:1px solid var(--border); border-radius:4px; background:var(--bg-deep); color:var(--text); font-size:11px; outline:none; cursor:pointer; }
.wf-mgr-sort-dir { width:24px; height:24px; border:1px solid var(--border); border-radius:4px; background:var(--bg-deep); color:var(--text); font-size:12px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .15s; }
.wf-mgr-sort-dir:hover { border-color:var(--accent); color:var(--accent); }
.wf-mgr-card.dim { opacity:.35; }
.wf-mgr-drag { display: inline-flex; align-items: center; justify-content: center;
  width: 24px; height: 24px; flex-shrink: 0; cursor: grab;
  border: 1px solid var(--border); border-radius: 4px;
  background: var(--bg-deep); color: var(--dim); font-size: 12px;
  -webkit-user-select: none; user-select: none; }
.wf-mgr-drag:active { cursor: grabbing; background: var(--accent); color: #000; border-color: var(--accent); }
.wf-overlay-upload { padding: 0 0 14px; }

/* ── Bottom Actions: Upload + Dirs ═══ */
.wf-bottom-actions {
  display: flex; gap: 14px; margin-top: 14px;
  border-top: 1px solid var(--border); padding-top: 14px;
}
.wf-bottom-actions .wf-overlay-upload {
  flex: 1; padding: 0; border: none; margin: 0;
}
.wf-bottom-actions .wf-dirs-section {
  flex: 1; padding: 0; border: none; margin: 0;
}
.wf-upload-zone {
  border: 2px dashed var(--border); border-radius: var(--radius);
  padding: 16px 12px; text-align: center; transition: all .2s;
  cursor: pointer; background: var(--bg-base);
}
.wf-upload-zone:hover, .wf-upload-zone.dragover {
  border-color: var(--accent); background: rgba(245,158,11,.06);
}
.wf-upload-zone.dragover { transform: scale(1.01); }
.wf-upload-icon { font-size: 28px; margin-bottom: 6px; }
.wf-upload-text { font-size: 13px; color: var(--text); margin-bottom: 4px; }
.wf-upload-hint { font-size: 11px; color: var(--dim); }
.wf-upload-btn {
  color: var(--accent); cursor: pointer; text-decoration: underline;
  font-size: 11px;
}
.wf-upload-btn:hover { color: var(--accent-dim); }
.wf-upload-progress {
  margin-top: 8px; font-size: 11px; color: var(--dim);
}
.wf-upload-ok { color: var(--green); }
.wf-upload-err { color: var(--red); }

/* ── Reference Image Section ── */
.ref-image-section {
  padding: 0 0 8px;
}
.ref-image-section > label {
  display: block; font-size: 12px; font-weight: 600; color: var(--dim); margin-bottom: 6px;
}

/* ── Image Upload for i2i ── */
.img-upload-zone {
  position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 100px; padding: 12px; border-radius: var(--radius);
  border: 2px dashed var(--border); background: var(--bg-deep);
  cursor: pointer; transition: border-color .2s, background .2s;
  overflow: hidden;
}
.img-upload-zone:hover, .img-upload-zone.dragover {
  border-color: var(--accent); background: rgba(245,158,11,.06);
}
.img-upload-placeholder {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  color: var(--dim); font-size: 13px; pointer-events: none;
}
.img-upload-preview {
  max-width: 100%; max-height: 200px; border-radius: 6px;
  object-fit: contain;
}

/* ── Remote Workflow Sync ── */

.wf-sync-section {
  padding: 0 0 14px;
}
.wf-sync-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px;
}
.wf-sync-title {
  font-size: 13px; font-weight: 600; color: var(--text);
  display: flex; align-items: center; gap: 4px;
}
.wf-sync-select { padding: 5px 8px; border: 1px solid var(--border); border-radius: 4px; background: var(--bg-deep); color: var(--text); font-size: 12px; outline: none; cursor: pointer; }
.wf-sync-btn {
  font-size: 11px; padding: 4px 10px; border-radius: 4px;
  border: 1px solid var(--accent); background: transparent;
  color: var(--accent); cursor: pointer; transition: all .15s;
}
.wf-sync-btn:hover { background: var(--accent); color: #000; }
.wf-sync-btn:disabled { opacity: .5; cursor: not-allowed; }
.wf-sync-status {
  font-size: 11px; padding: 6px 8px; background: var(--bg-base);
  border-radius: 4px; color: var(--dim);
}
.wf-sync-ok { color: var(--green) !important; }
.wf-sync-err { color: var(--red) !important; }

/* ── Workflow Directory Management ── */

.wf-dirs-section {
  padding: 0;
}
.wf-dirs-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px;
}
.wf-dirs-title {
  font-size: 13px; font-weight: 600; color: var(--text);
}
.wf-dirs-add-btn {
  height: 26px; padding: 0 10px; border-radius: 6px;
  background: var(--bg-elevated); border: 1px solid var(--border);
  color: var(--accent); font-size: 12px; cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center;
  white-space: nowrap; gap: 2px;
  transition: border-color .15s, background .15s;
}
.wf-dirs-add-btn:hover { border-color: var(--accent); background: rgba(245,158,11,.08); }
.wf-dirs-list { display: flex; flex-direction: column; gap: 4px; }
.wf-dir-item {
  display: flex; align-items: center; gap: 8px;
  padding: 6px 10px; border-radius: 6px;
  background: var(--bg-deep); border: 1px solid var(--border);
  font-size: 12px; font-family: var(--font-mono);
  transition: border-color .15s;
}
.wf-dir-item:hover { border-color: var(--accent); }
.wf-dir-path { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text); }
.wf-dir-count { color: var(--dim); font-size: 11px; flex-shrink: 0; }
.wf-dir-missing { color: var(--red); font-size: 11px; flex-shrink: 0; }
.wf-dir-del {
  width: 22px; height: 22px; border-radius: 4px;
  background: transparent; border: 1px solid transparent;
  color: var(--dim); font-size: 14px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: all .15s;
}
.wf-dir-del:hover { border-color: var(--red); color: var(--red); background: rgba(239,68,68,.08); }
.wf-dirs-add {
  display: flex; gap: 6px; margin-top: 8px; align-items: center;
}
.wf-dir-input {
  flex: 1; padding: 6px 10px; border-radius: 6px;
  background: var(--bg-deep); border: 1px solid var(--border);
  color: var(--text); font-size: 12px;
  font-family: var(--font-mono);
  outline: none; transition: border-color .15s;
}
.wf-dir-input:focus { border-color: var(--accent); }
.wf-dir-add-confirm, .wf-dir-add-cancel {
  padding: 6px 12px; border-radius: 6px; font-size: 12px;
  cursor: pointer; border: 1px solid var(--border); flex-shrink: 0;
  transition: all .15s;
}
.wf-dir-add-confirm { background: var(--accent); border-color: var(--accent); color: #000; }
.wf-dir-add-confirm:hover { filter: brightness(1.15); }
.wf-dir-add-cancel { background: var(--bg-elevated); color: var(--dim); }
.wf-dir-add-cancel:hover { border-color: var(--dim); color: var(--text); }

.wf-overlay-grid {
  display: flex;
  flex-direction: column;
  max-height: 480px;
  overflow-y: auto;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow-x: hidden;
}

.wf-overlay-empty {
  text-align: center; color: var(--dim); padding: 60px 0; font-size: 14px;
}

/* ── Workflow Card in Overlay ── */

.wf-mgr-card {
  display: flex; align-items: center; gap: 12px; padding: 8px 10px;
  border-bottom: 1px solid var(--border); transition: background .15s;
  background: var(--bg-glass);
  backdrop-filter: blur(12px) saturate(1.1);
  -webkit-backdrop-filter: blur(12px) saturate(1.1);
  animation: cardIn 0.35s ease both;
}
.wf-mgr-card:last-child { border-bottom: none; }
.wf-mgr-card:hover { background: var(--bg-elevated); }

/* Tag-colored card backgrounds */
.wf-mgr-card[data-cat="图生图"] { background: rgba(139,92,246,.06); }
.wf-mgr-card[data-cat="图生图"]:hover { background: rgba(139,92,246,.12); }
.wf-mgr-card[data-cat="文生图"] { background: rgba(245,158,11,.06); }
.wf-mgr-card[data-cat="文生图"]:hover { background: rgba(245,158,11,.12); }
.wf-mgr-card[data-cat="文生视频"] { background: rgba(245,158,11,.06); }
.wf-mgr-card[data-cat="文生视频"]:hover { background: rgba(245,158,11,.12); }
.wf-mgr-card[data-cat="图生视频"] { background: rgba(245,158,11,.06); }
.wf-mgr-card[data-cat="图生视频"]:hover { background: rgba(245,158,11,.12); }
.wf-mgr-card[data-cat="放大"] { background: rgba(34,197,94,.06); }
.wf-mgr-card[data-cat="放大"]:hover { background: rgba(34,197,94,.12); }

.wf-mgr-thumb { object-fit: cover; width: 50px; height: 50px; border-radius: 6px; flex-shrink: 0; background: var(--bg-deep); border: 1px solid var(--border); }
.wf-mgr-thumb.empty { background: var(--bg-base); }

.wf-mgr-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; font-weight: 500; color: var(--text); }
.wf-mgr-name .wf-mgr-tags { display: inline-flex; white-space: nowrap; margin-left: 6px; gap: 5px; }
.wf-mgr-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.wf-mgr-tags {
  display: inline-flex; flex-wrap: nowrap; gap: 5px; flex-shrink: 0;
}
.wf-mgr-tag {
  font-size: 10px; padding: 2px 6px; border-radius: 4px; margin-right: 5px;
  background: rgba(245,158,11,.12); color: var(--accent);
}
.wf-mgr-tag.t2i { background: rgba(245,158,11,.12); color: var(--accent); }
.wf-mgr-tag.i2i { background: rgba(139,92,246,.15); color: var(--purple); }
.wf-mgr-tag.t2v { background: rgba(245,158,11,.12); color: var(--orange); }
.wf-mgr-tag.i2v { background: rgba(245,158,11,.12); color: var(--orange); }
.wf-mgr-tag.cat { background: rgba(34,197,94,.12); color: var(--green); }
.wf-mgr-tag.res { background: rgba(245,158,11,.12); color: var(--orange); }

.wf-mgr-actions {
  display: flex; gap: 6px; flex-shrink: 0;
}
.wf-mgr-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 4px;
  padding: 3px 10px; min-height: 22px;
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: var(--bg-deep); color: var(--dim); font-size: 11px; cursor: pointer;
  transition: all .15s; font-family: var(--font-sans); white-space: nowrap;
  line-height: 1;
}
.wf-mgr-btn svg { display: block; flex-shrink: 0; }
.wf-mgr-btn:hover { border-color: var(--accent); color: var(--accent); }
.wf-mgr-btn.danger { color: var(--red); border-color: rgba(239,68,68,.3); }
.wf-mgr-btn.danger:hover { border-color: var(--red); color: var(--red); background: rgba(239,68,68,.08); }

/* Colored button variants */
.wf-mgr-btn.btn-start { background: rgba(34,197,94,.15); color: var(--green); border-color: rgba(34,197,94,.3); }
.wf-mgr-btn.btn-start:hover { background: rgba(34,197,94,.25); }
.wf-mgr-btn.btn-stop { background: rgba(239,68,68,.15); color: var(--red); border-color: rgba(239,68,68,.3); }
.wf-mgr-btn.btn-stop:hover { background: rgba(239,68,68,.25); }
.wf-mgr-btn.btn-open { background: rgba(59,130,246,.15); color: var(--blue); border-color: rgba(59,130,246,.3); }
.wf-mgr-btn.btn-open:hover { background: rgba(59,130,246,.25); }

/* ── Edit Modal ── */

.wf-edit-modal {
  display: none; position: fixed; inset: 0; z-index: 1100;
  background: rgba(0,0,0,.6); backdrop-filter: blur(4px);
  align-items: center; justify-content: center;
}
.wf-edit-modal.open { display: flex; }

.wf-edit-card {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius);
  width: 420px; max-width: 90vw; max-height: 80vh; overflow-y: auto;
}

.wf-edit-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px; border-bottom: 1px solid var(--border);
}
.wf-edit-title { font-size: 15px; font-weight: 700; }
.wf-edit-close {
  background: none; border: none; color: var(--dim); font-size: 18px;
  cursor: pointer; padding: 4px;
}
.wf-edit-close:hover { color: var(--text); }

.wf-edit-body { padding: 16px; }

.wf-edit-row { margin-bottom: 14px; }
.wf-edit-row label {
  display: block; font-size: 12px; font-weight: 600; color: var(--dim);
  margin-bottom: 6px;
}
.wf-edit-row input[type="text"] {
  width: 100%; padding: 8px 10px; border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: var(--bg-deep); color: var(--text); font-size: 13px; font-family: var(--font-sans);
}
.wf-edit-row input[type="text"]:focus { outline: none; border-color: var(--accent); }

.wf-edit-tags {
  display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px;
}
.wf-edit-tag {
  display: flex; align-items: center; gap: 4px;
  font-size: 11px; padding: 3px 8px; border-radius: 4px;
  background: rgba(245,158,11,.12); color: var(--accent);
}
.wf-edit-tag-remove {
  cursor: pointer; font-size: 10px; opacity: .6;
}
.wf-edit-tag-remove:hover { opacity: 1; }

.wf-edit-tag-add select {
  padding: 3px 8px; border: 1px dashed var(--border); border-radius: 4px;
  background: var(--bg-deep); color: var(--dim); font-size: 11px;
  cursor: pointer; font-family: var(--font-sans);
}
.wf-edit-tag-add select:focus { outline: none; border-color: var(--accent); }

.wf-edit-thumb {
  width: 100%; aspect-ratio: 16/9; background: var(--bg-deep); border: 1px dashed var(--border);
  border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;
  cursor: pointer; overflow: hidden; transition: border-color .15s; position: relative;
}
.wf-edit-thumb:hover { border-color: var(--accent); }
.wf-edit-thumb img { width: 100%; height: 100%; object-fit: contain; }
.wf-edit-thumb-placeholder { font-size: 28px; color: var(--dim); opacity: .5; }

.wf-edit-footer {
  display: flex; gap: 8px; justify-content: flex-end;
  padding: 12px 16px; border-top: 1px solid var(--border);
}
.wf-edit-cancel { background: var(--bg-deep); border: 1px solid var(--border); color: var(--dim); }
.wf-edit-cancel:hover { border-color: var(--dim); color: var(--text); }

/* ── Delete Modal ── */

.wf-del-modal {
  display: none; position: fixed; inset: 0; z-index: 1200;
  background: rgba(0,0,0,.6); backdrop-filter: blur(4px);
  align-items: center; justify-content: center;
}
.wf-del-modal.open { display: flex; }

.wf-del-card {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius);
  width: 360px; max-width: 90vw; padding: 20px;
}
.wf-del-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.wf-del-msg { font-size: 13px; color: var(--dim); margin-bottom: 16px; }
.wf-del-actions { display: flex; gap: 8px; justify-content: flex-end; }
.wf-del-cancel { background: var(--bg-deep); border: 1px solid var(--border); color: var(--dim); }
.wf-del-cancel:hover { border-color: var(--dim); color: var(--text); }
.wf-del-confirm { background: var(--red); color: #fff; border: none; }
.wf-del-confirm:hover { background: #ff6b6b; }

@media (max-width: 900px) {
  .wf-edit-card { width: 95vw; }
}

/* ═══ Device Cards ═══ */
.device-pane { padding: 8px 16px 16px; }
.device-pane-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--border); margin-bottom: 12px; }
.device-pane-title { font-weight: 600; font-size: 14px; color: var(--text); }
.device-list { display: flex; flex-direction: column; gap: 12px; }

.device-card {
  background: var(--bg-glass);
  backdrop-filter: blur(12px) saturate(1.1);
  -webkit-backdrop-filter: blur(12px) saturate(1.1);
  border: 1px solid var(--border);
  border-radius: var(--radius-glass);
  box-shadow: var(--shadow-glass);
  padding: 14px 16px;
  animation: cardIn 0.35s ease both;
}
.device-card:hover { border-color: var(--border-hover); transform: translateY(-1px); }
.device-card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.device-card-title { font-weight: 600; font-size: 15px; color: var(--text); flex: 1; }
.device-status-tag { font-size: 12px; color: var(--dim); }

.device-card-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
.device-card-addr { font-size: 12px; color: var(--dim); font-family: var(--font-mono); flex: 1; }

.device-instance-header { display: flex; align-items: center; gap: 8px; padding: 6px 8px; font-size: 11px; color: var(--dim); font-weight: 600; border-bottom: 1px solid var(--border); }
.device-instance-row { display: flex; align-items: center; gap: 8px; padding: 6px 8px; font-size: 12px; border-bottom: 1px solid rgba(255,255,255,.04); }
.device-instance-row:last-child { border-bottom: none; }

.dih-col { flex-shrink: 0; }
.dih-name { flex: 2; display: flex; align-items: center; gap: 6px; }
.dih-port { flex: 1; color: var(--dim); font-family: var(--font-mono); }
.dih-status { flex: 1; }
.dih-queue { flex: 0.6; color: var(--dim); }
.dih-actions { flex: 3; display: flex; gap: 4px; justify-content: flex-end; }
.dih-actions .wf-mgr-btn { font-size: 11px; padding: 2px 8px; }

.device-card-footer { display: flex; gap: 6px; padding-top: 8px; margin-top: 8px; border-top: 1px solid var(--border); flex-wrap: wrap; }

@media(max-width:600px) {
  .device-instance-header, .device-instance-row { font-size: 11px; gap: 3px; }
  .dih-queue { display: none; }
}

/* ═══ Device Editor Modal ═══ */
.de-modal{position:fixed;inset:0;z-index:1200;display:none;place-items:center;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
.de-modal.open{display:grid}
.de-card{width:90vw;max-width:600px;max-height:85vh;background:var(--bg-elevated);border-radius:var(--radius-glass);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow-lg)}
.de-header{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border)}
.de-title{font-size:16px;font-weight:600;color:var(--text)}
.de-close{background:none;border:none;font-size:18px;color:var(--dim);cursor:pointer}
.de-close:hover{color:var(--text)}
.de-form{flex:1;overflow-y:auto;padding:0}
.de-section{padding:14px 18px;border-bottom:1px solid var(--border)}
.de-section-title{font-size:13px;font-weight:600;color:var(--accent);margin-bottom:10px}
.de-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.de-label{width:90px;flex-shrink:0;font-size:12px;color:var(--dim);text-align:right}
.de-input{flex:1;padding:7px 10px;border:1px solid var(--border);border-radius:6px;background:rgba(255,255,255,.06);color:var(--text);font-size:13px;outline:none;font-family:var(--font-sans)}
.de-input:focus{border-color:var(--accent)}
.de-input-sm{max-width:100px}
.de-input::placeholder{color:var(--dim)}
.de-hint{font-size:11px;color:var(--dim);padding:2px 0 0 100px;margin-top:-4px;margin-bottom:4px}
.de-hint code{background:rgba(255,255,255,.08);padding:1px 5px;border-radius:3px;font-size:11px}
.de-inst-list{display:flex;flex-wrap:wrap;gap:6px}
.de-inst-tag{background:rgba(245,158,11,.15);color:var(--accent);padding:3px 8px;border-radius:4px;font-size:11px;font-family:var(--font-mono)}
.de-footer{display:flex;justify-content:flex-end;gap:8px;padding:12px 18px;border-top:1px solid var(--border)}

/* ═══ Node Editor ═══ */
.ne-modal{position:fixed;inset:0;z-index:1200;display:none;place-items:center;background:rgba(0,0,0,.65);backdrop-filter:blur(4px)}
.ne-modal.open{display:grid}
.ne-card{width:95vw;max-width:1200px;height:85vh;background:var(--bg-elevated);border-radius:var(--radius-glass);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow-lg)}
.ne-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border)}
.ne-title{font-size:16px;font-weight:600;color:var(--text)}
.ne-close{background:none;border:none;font-size:20px;color:var(--dim);cursor:pointer}
.ne-close:hover{color:var(--text)}
.ne-body{flex:1;overflow-y:auto;padding:12px 16px}
.ne-instructions{font-size:12px;color:var(--dim);margin-bottom:12px;padding:8px 12px;background:rgba(255,255,255,.04);border-radius:6px;}
.ne-zones{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;min-height:300px}
@media(max-width:900px){.ne-zones{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.ne-zones{grid-template-columns:1fr}}
.ne-zone{background:rgba(255,255,255,.03);border-radius:8px;border:2px dashed transparent;min-height:200px;transition:border-color .2s,background .2s}
.ne-zone.drag-over{border-color:var(--accent);background:rgba(245,158,11,.08)}
.ne-zone-title{font-size:13px;font-weight:600;padding:10px 12px 6px;color:var(--text);border-bottom:1px solid var(--border);position:sticky;top:0;background:inherit;z-index:1}
.ne-zone-cards{padding:8px;display:flex;flex-direction:column;gap:6px;min-height:100px;min-width:0}
.ne-field{display:block;background:var(--bg-card);border-radius:6px;padding:8px 10px;cursor:grab;user-select:none;border:1px solid var(--border);transition:opacity .2s;overflow:hidden}
.ne-field:active{cursor:grabbing}
.ne-field[draggable="true"]:hover{border-color:var(--accent)}
.ne-field.hidden-field{opacity:.5}
.ne-field-top{display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:4px}
.ne-field-node{font-size:11px;color:var(--dim);font-family:var(--font-mono);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px}
.ne-field-vis{background:none;border:none;font-size:14px;cursor:pointer;padding:2px;line-height:1;opacity:.6;transition:opacity .2s}
.ne-field-vis:hover{opacity:1}
.ne-field-name{font-size:12px;color:var(--accent);font-family:var(--font-mono);margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
.ne-field-label-input{overflow-wrap:break-word;word-break:break-word;white-space:normal;width:100%;font-size:12px;padding:3px 6px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:4px;color:var(--text);margin-bottom:3px}
.ne-field-label-input:focus{border-color:var(--accent);outline:none}
.ne-field-value{font-size:11px;color:var(--dim);overflow:hidden;text-overflow:ellipsis;max-width:100%;word-break:break-all}
.ne-footer-spacer{flex:1}
.ne-reset{color:var(--dim)!important}

.inst-popup-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:900;animation:fadeIn .15s}
.inst-popup-overlay.open{display:flex;align-items:center;justify-content:center}
.inst-popup{background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-glass);width:400px;max-width:95vw;padding:20px;box-shadow:var(--shadow-lg);animation:slideUp .2s}
.inst-popup-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
.inst-popup-header h3{margin:0;font-size:15px;color:var(--text)}
.inst-popup-close{background:none;border:none;color:var(--dim);font-size:20px;cursor:pointer;padding:4px 8px;border-radius:6px}
.inst-popup-close:hover{background:var(--bg-elevated);color:var(--text)}
.inst-card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-glass);padding:14px;margin-bottom:12px}
.inst-card.on{background:rgba(34,197,94,0.20);border:1.5px solid rgba(34,197,94,0.7);box-shadow:0 0 15px rgba(34,197,94,0.25);}
.inst-card.off{background:rgba(80,80,80,0.25);border:1px solid rgba(80,80,80,0.2);opacity:0.50;filter:grayscale(0.5);}
.inst-card:last-child{margin-bottom:0}
.inst-card + .inst-card{margin-top:14px}
.inst-card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.inst-card-name{display:flex;align-items:center;gap:12px;font-weight:600;font-size:14px;color:var(--text)}
.inst-led{width:10px;height:10px;border-radius:50%;background:var(--dim);flex-shrink:0}
.inst-led.on{background:var(--green);box-shadow:0 0 6px rgba(34,197,94,.53)}
.inst-led.off{background:var(--red)}
.inst-card-btn{padding:5px 14px;border:1px solid var(--border);border-radius:6px;background:var(--bg-deep);color:var(--text);font-size:12px;cursor:pointer;transition:all .15s}
.inst-card-btn:hover{border-color:var(--accent)}
.inst-card-btn.stop{border-color:var(--red);color:var(--red)}
.inst-card-btn.stop:hover{background:rgba(239,68,68,.15)}
.inst-card-btn.start{border-color:var(--green);color:var(--green)}
.inst-card-btn.start:hover{background:rgba(34,197,94,.15)}
.inst-card-btn:disabled{opacity:.4;cursor:not-allowed}
.inst-card-row{display:flex;justify-content:space-between;font-size:12px;color:var(--dim);padding:3px 0}
.inst-card-row .val{color:var(--text);font-weight:500}
.inst-card-row .val.active{color:var(--green)}
.inst-card-row .val.pending{color:var(--orange)}
.inst-card-group{display:inline-block;font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(245,158,11,.15);color:var(--accent);margin-top:4px}
.gpu-card{background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-glass);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;gap:10px}
.gpu-card-info{flex:1;min-width:0}
.gpu-card-name{font-size:13px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.gpu-card-detail{font-size:11px;color:var(--dim);margin-top:2px}
.gpu-card-mem{font-size:12px;font-weight:600;color:var(--accent);white-space:nowrap}
.gpu-card-kill{padding:4px 12px;border:1px solid var(--red);border-radius:6px;background:transparent;color:var(--red);font-size:11px;cursor:pointer;white-space:nowrap}
.gpu-card-kill:hover{background:rgba(239,68,68,.15)}
.gpu-card-kill:disabled{opacity:.4;cursor:not-allowed}
.popup-section-title{font-size:12px;color:var(--dim);text-transform:uppercase;letter-spacing:1px;margin:12px 0 8px;padding-top:12px;border-top:1px solid var(--border)}
.popup-section-title:first-child{margin-top:0;padding-top:0;border-top:none}
.wf-tag-inline{font-size:9px}

/* Workflow card type accents (via data-cat attribute) */
.wf-card[data-cat="文生图"] { background: rgba(245,158,11,0.12); }
.wf-card[data-cat="图生图"] { background: rgba(139,92,246,0.12); }
.wf-card[data-cat="文生视频"] { background: rgba(245,158,11,0.10); }
.wf-card[data-cat="图生视频"] { background: rgba(245,158,11,0.10); }
.wf-card[data-cat="放大"] { background: rgba(34,197,94,0.10); }
.wf-card[data-cat="文生图"].active { background: rgba(245,158,11,0.30); }
.wf-card[data-cat="图生图"].active { background: rgba(139,92,246,0.30); }
.wf-card[data-cat="文生视频"].active { background: rgba(245,158,11,0.25); }
.wf-card[data-cat="图生视频"].active { background: rgba(245,158,11,0.25); }
.wf-card[data-cat="放大"].active { background: rgba(34,197,94,0.25); }
.wf-card:hover { border-color: rgba(245,158,11,.4); box-shadow: 0 0 0 1px rgba(245,158,11,.2); }
.wf-card[data-cat="图生图"]:hover { border-color: rgba(139,92,246,.4); box-shadow: 0 0 0 1px rgba(139,92,246,.2); }
.wf-card[data-cat="文生图"]:hover { border-color: rgba(245,158,11,.4); box-shadow: 0 0 0 1px rgba(245,158,11,.2); }
.wf-card[data-cat="文生视频"]:hover { border-color: rgba(245,158,11,.4); box-shadow: 0 0 0 1px rgba(245,158,11,.2); }
.wf-card[data-cat="图生视频"]:hover { border-color: rgba(245,158,11,.4); box-shadow: 0 0 0 1px rgba(245,158,11,.2); }
.wf-card[data-cat="放大"]:hover { border-color: rgba(34,197,94,.4); box-shadow: 0 0 0 1px rgba(34,197,94,.2); }
.gi-timer-row{padding:2px 0 0;font-size:11px;color:var(--accent);font-variant-numeric:tabular-nums}
.job-timer-big{font-weight:600;font-size:12px;color:var(--accent);font-variant-numeric:tabular-nums;padding:2px 0 0}

/* Workflow manager thumb in overlay */
.wf-mgr-thumb { cursor: pointer; text-align: center; }
.wf-mgr-thumb img { width: 50px; height: 50px; object-fit: cover; border-radius: 6px; display: block; }
.wf-mgr-thumb-placeholder { width: 50px; height: 50px; border-radius: 6px; background: var(--bg-base); border: 1px dashed var(--border); display: flex; align-items: center; justify-content: center; font-size: 20px; }
.wf-mgr-thumb-edit { font-size: 10px; color: var(--dim); margin-top: 2px; white-space: nowrap; }

.wf-mgr-body { display: flex; flex-direction: row; align-items: center; gap: 12px; flex: 1; min-width: 0; }
.wf-mgr-info { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; justify-content: center; }
.wf-mgr-filename { font-size: 11px; color: var(--dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wf-mgr-actions { display: flex; gap: 6px; flex-shrink: 0; align-items: center; }
.wf-grid.dragging { cursor: grabbing; user-select: none; }

/* ═══ Toast Notifications ═══ */
.toast-container {
  position: fixed; top: 10px; left: 50%; transform: translateX(-50%); z-index: 9999;
  display: flex; flex-direction: column; gap: 8px; pointer-events: none; align-items: center;
}
.toast {
  pointer-events: auto;
  padding: 12px 24px; border-radius: var(--radius-glass); font-size: 14px;
  background: var(--bg-elevated); border: 1px solid var(--border);
  color: var(--text); box-shadow: var(--shadow-lg);
  display: flex; align-items: center; gap: 10px;
  animation: toastIn .35s ease, toastOut .4s ease 9.6s forwards;
  max-width: 480px; min-width: 300px;
}
.toast-icon { font-size: 16px; flex-shrink: 0; }
.toast-queued { border-left: 3px solid var(--yellow); background: rgba(234,179,8,.08); }
.toast-generating { border-left: 3px solid var(--accent); background: rgba(245,158,11,.08); }
.toast-done { border-left: 3px solid var(--green); background: rgba(34,197,94,.08); }
.toast-error { border-left: 3px solid var(--red); background: rgba(239,68,68,.08); }
.gi-seed{font-size:9px;color:var(--dim);padding:2px 0 0;font-variant-numeric:tabular-nums;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ═══ History Card: info at bottom ═══ */
.gi:not(.job-card) {
  height: 280px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.gi:not(.job-card) .gi-img {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}
.gi:not(.job-card) .gi-img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.gi:not(.job-card) .gi-info {
  border-top: 1px solid var(--border);
  padding: 6px 8px 7px;
  flex-shrink: 0;
  transition: padding .25s ease;
  background: var(--bg-elevated);
}
.gi:not(.job-card):hover .gi-info {
  padding: 10px 8px 8px;
}
.gi:not(.job-card) .gi-meta,
.gi:not(.job-card) .gi-seed {
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transition: opacity .2s ease, max-height .2s ease;
}
.gi:not(.job-card):hover .gi-meta,
.gi:not(.job-card):hover .gi-seed {
  opacity: 1;
  max-height: 40px;
}
.gi:not(.job-card) .gi-meta {
  margin-top: 4px;
}
.gi:not(.job-card) .gi-prompt {
  font-size: 12px;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 32px;
}
.gi:not(.job-card):hover .gi-prompt {
  -webkit-line-clamp: 3;
}

/* ═══ Animated gradient background for generating job cards ═══ */

.gi-img.job-placeholder {
  aspect-ratio: unset;
  background: var(--bg-deep);
  background-image:
    radial-gradient(ellipse at 25% 45%, rgba(245,158,11,.5) 0%, transparent 55%),
    radial-gradient(ellipse at 75% 25%, rgba(139,92,246,.45) 0%, transparent 55%);
  background-size: 250% 250%, 250% 250%;
  animation: gradShift 12s ease infinite;
}

.gi.job-card.generating {
  animation: cryptoGlow 6s ease infinite;
}

/* ═══ downloading state ═══ */
.gi.job-card.downloading {
  border-color: var(--yellow);
  border-style: solid;
  animation: cryptoGlow 6s ease infinite;
}

.gi.job-card.downloading .gi-img.job-placeholder {
  aspect-ratio: unset;
  background: var(--bg-deep);
  background-image:
    radial-gradient(ellipse at 30% 40%, rgba(245,158,11,.5) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 60%, rgba(34,197,94,.4) 0%, transparent 50%);
  background-size: 250% 250%, 250% 250%;
  animation: gradShift 12s ease infinite;
}

.gi.job-card.downloading .job-status-text {
  color: var(--yellow);
}

/* Error state */
.gi.job-card.error .gi-img.job-placeholder {
  background: rgba(239,68,68,.15) !important;
  animation: none !important;
  background-image: none !important;
}
.gi.job-card.error .job-spinner { display: none !important; }
.gi.job-card.error .gi-img.job-placeholder::before { content: ""; position: absolute; top: 50%; left: 50%; width: 40px; height: 40px; transform: translate(-50%, -50%); background: url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%23ef4444%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3E%3Ccircle cx=%2712%27 cy=%2712%27 r=%2710%27/%3E%3Cline x1=%2715%27 y1=%279%27 x2=%279%27 y2=%2715%27/%3E%3Cline x1=%279%27 y1=%279%27 x2=%2715%27 y2=%2715%27/%3E%3C/svg%3E") no-repeat center; background-size: contain; z-index: 2; }
.gi.job-card.error {
  border-color: var(--red);
  box-shadow: none !important;
  animation: none !important;
}

/* Workflow version management */
.wf-edit-versions { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; }
.wf-edit-version-upload { display: flex; align-items: center; gap: 8px; }
.wf-edit-version-hint { font-size: 10px; color: var(--dim); }
.wf-edit-version-list { display: flex; flex-direction: column; gap: 3px; max-height: 120px; overflow-y: auto; }
.wf-version-item { display: flex; align-items: center; gap: 8px; padding: 4px 8px; border-radius: 4px; background: var(--bg-deep); font-size: 12px; }
.wf-version-item.active { background: rgba(245,158,11,.12); }
.wf-version-name { flex-shrink: 0; font-weight: 500; color: var(--text); }
.wf-version-badge { font-size: 10px; color: var(--accent); margin-right: 4px; }
.wf-version-filename { font-size: 10px; color: var(--dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 60px; flex: 1; }
.wf-version-actions { display: flex; align-items: center; gap: 6px; margin-left: auto; flex-shrink: 0; }
.wf-version-activate { font-size: 11px; }

.gi.job-card.queued .gi-img.job-placeholder {
  animation: none;
  background: rgba(245, 158, 11, 0.10);
  background-position: 0% 50%, 50% 0%, 100% 50%;
}
.gi.job-card.preparing .gi-img.job-placeholder,
.gi.job-card.dispatching .gi-img.job-placeholder,
.gi.job-card.starting_comfyui .gi-img.job-placeholder {
  animation: none;
  background: rgba(245, 158, 11, 0.08);
}

/* ═══ Mobile: Workflow Manager ═══ */
@media (max-width: 600px) {
  .wf-mgr-card {
    flex-wrap: wrap;
    gap: 0;
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-deep);
    border-radius: 8px;
    margin-bottom: 6px;
  }
  .wf-mgr-card:last-child { margin-bottom: 0; }
  .wf-mgr-card:hover { background: var(--bg-deep); }

  .wf-mgr-thumb { display: none; }

  .wf-mgr-drag {
    display: inline-flex; align-items: center; justify-content: center;
    width: 24px; height: 24px; flex-shrink: 0; cursor: grab;
    border: 1px solid var(--border); border-radius: 4px;
    background: var(--bg-deep); color: var(--dim); font-size: 12px;
    margin-right: 8px; vertical-align: middle;
    -webkit-user-select: none; user-select: none;
  }
  .wf-mgr-drag:active { cursor: grabbing; background: var(--accent); color: #fff; border-color: var(--accent); }

  .wf-mgr-body {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column; gap: 6px;
  }

  .wf-mgr-info {
    width: 100%; min-width: 0;
    display: flex; flex-direction: column; gap: 2px;
  }

  .wf-mgr-name {
    font-size: 14px; font-weight: 600; color: var(--text);
    white-space: normal; word-break: break-word;
    line-height: 1.3;
  }
  .wf-mgr-name .wf-mgr-tags {
    display: inline; margin-left: 4px; vertical-align: middle;
  }
  .wf-mgr-name .wf-mgr-tags .wf-mgr-tag {
    font-size: 10px; padding: 1px 5px;
  }

  .wf-mgr-filename {
    font-size: 11px; color: var(--dim);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  .wf-mgr-actions {
    display: flex; gap: 8px; width: 100%;
    justify-content: stretch; flex-wrap: nowrap;
  }
  .wf-mgr-btn {
    flex: 1; padding: 8px 0; border: 1px solid var(--border);
    border-radius: 6px; background: var(--bg-deep); color: var(--dim);
    font-size: 12px; cursor: pointer; text-align: center;
    white-space: nowrap; transition: all .15s;
    min-height: 36px;
  }
  .wf-mgr-btn:active { background: var(--bg-elevated); }
  .wf-mgr-btn.danger { color: var(--red); border-color: rgba(239,68,68,.3); }
  .wf-mgr-btn.danger:active { background: rgba(239,68,68,.15); }

  .wf-mgr-toolbar { padding: 8px 12px; gap: 8px; }
  .wf-mgr-filter-tabs { gap: 4px; overflow-x: auto; flex-wrap: nowrap; -webkit-overflow-scrolling: touch; }
  .wf-mgr-filter-tab { font-size: 11px; padding: 5px 10px; white-space: nowrap; }
  .wf-mgr-sort { gap: 4px; }
  .wf-mgr-sort-label { font-size: 11px; }
  .wf-mgr-sort-select { font-size: 11px; padding: 3px 6px; }

  .wf-overlay-grid { max-height: none; border: none; border-radius: 0; }
}

/* ── Status Module ═══ */
.dim-tag { color: var(--dim); font-size: 11px; }
.st-empty { color: var(--dim); font-size: 12px; padding: 8px; }
.st-error { color: var(--red); font-size: 12px; padding: 8px; }

.gpu-bar { flex: 1; height: 8px; border-radius: 2px; }
.gpu-green { background: var(--green); min-width: 4px; }
.gpu-yellow { background: var(--accent); opacity: 0.6; min-width: 4px; }
.gpu-empty { background: var(--border); }

.btn-svg { vertical-align: middle; margin-right: 5px; }

/* ── Generate Module ═══ */
.clear-btn {
  position: absolute; top: 4px; right: 4px;
  background: rgba(0,0,0,.4); border: 1px solid rgba(255,255,255,.15);
  color: #fff; font-size: 11px; padding: 3px 10px;
  border-radius: 4px; cursor: pointer;
}
.hidden { display: none !important; }
.sep-dim { margin: 0 4px; color: var(--dim); }
.gen-empty { color: var(--dim); font-size: 12px; padding: 6px 0; }

.toggle-label { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; }
.toggle-label input[type=checkbox] { display: none; }
.toggle-slider { width: 36px; height: 20px; background: var(--border); border-radius: 10px; position: relative; transition: background .2s; }
.toggle-slider::after { content: ""; position: absolute; top: 2px; left: 2px; width: 16px; height: 16px; background: #fff; border-radius: 50%; transition: transform .2s; }
.toggle-label input:checked + .toggle-slider { background: var(--accent); }
.toggle-label input:checked + .toggle-slider::after { transform: translateX(16px); }

/* ── Workflow Module ═══ */
.wf-empty { padding:12px; color:var(--dim); text-align:center; font-size:12px; }
.wf-tag-sm { font-size:8px; padding:0 3px; margin-left:2px; }
.wf-err-tag { color:var(--red); font-size:11px; }

/* ── History Module ═══ */
.hint-sub { font-size:11px; margin-top:4px; }

/* ── Icons Module ═══ */
.cw-icon { vertical-align: middle; display: inline-block; flex-shrink: 0; }
.cw-icon-svg { vertical-align:middle; display:inline-block; flex-shrink:0; }

/* ── Log Panel ═══ */
.tb-log-btn {
  background: none; border: 1px solid var(--border); color: var(--text);
  padding: 3px 10px; border-radius: 4px; cursor: pointer; font-size: 12px;
  display: inline-flex; align-items: center; gap: 4px; white-space: nowrap;
}
.tb-log-btn:hover { background: var(--border); }

.log-panel {
  position: fixed; top: 50px; right: 10px; width: 500px; max-width: 95vw; max-height: 70vh;
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-radius: var(--radius); box-shadow: 0 8px 32px rgba(0,0,0,.5);
  z-index: 1000; display: flex; flex-direction: column; overflow: hidden;
}
@media (max-width: 600px) {
  .log-panel { top: 44px; right: 5px; left: 5px; width: auto; }
}
.log-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 12px; border-bottom: 1px solid var(--border);
  font-weight: 600; font-size: 13px;
}
.log-close-btn {
  background: none; border: none; color: var(--dim); cursor: pointer;
  font-size: 16px; padding: 2px 6px; border-radius: 3px;
}
.log-close-btn:hover { background: var(--border); color: var(--text); }
.log-body {
  flex: 1; overflow-y: auto; padding: 4px 0; font-size: 11px;
  font-family: var(--font-mono);
}
.log-entry { padding: 3px 12px; border-bottom: 1px solid var(--border); line-height: 1.4; }
.log-entry .log-time { color: var(--dim); margin-right: 6px; }
.log-entry .log-level { font-weight: 600; margin-right: 4px; }
.log-entry .log-level.info { color: var(--accent); }
.log-entry .log-level.warn { color: var(--yellow); }
.log-entry .log-level.error { color: var(--red); }
.log-entry .log-phase { color: var(--purple); margin-right: 4px; }
.log-entry .log-msg { color: var(--text); }
.log-entry .log-details { color: var(--dim); font-size: 10px; margin-top: 1px; white-space: pre-wrap; }

/* ═══ Auth Module ═══ */
/* ═══════════════════════════════════════════
   Unified Modal System — V4 Glassmorphism
   Shared by auth, workflow-edit, device-edit, node-editor
   ═══════════════════════════════════════════ */

/* ── Base overlay ── */
.auth-modal-overlay,
.de-modal,
.ne-modal,
.wf-edit-modal {
  position: fixed; inset: 0;
  z-index: 9999;
  display: none;
  place-items: center;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  align-items: center;
  justify-content: center;
}
.auth-modal-overlay.open,
.de-modal.open,
.ne-modal.open,
.wf-edit-modal.open { display: flex; }

/* ── Shared card ── */
.auth-modal,
.de-card,
.ne-card,
.wf-edit-card {
  width: 90vw;
  max-width: 600px;
  max-height: 90vh;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(245,158,11,0.05);
  position: relative;
}
.auth-modal { width: 360px; }
.ne-card { width: 95vw; max-width: 1200px; height: 85vh; }

/* ── Shared header ── */
.auth-modal-header,
.de-header,
.ne-header,
.wf-edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px 12px;
  border-bottom: 1px solid var(--border);
  background: linear-gradient(180deg, rgba(245,158,11,0.04) 0%, transparent 100%);
}

/* ── Shared title ── */
.auth-modal-title,
.de-title,
.ne-title,
.wf-edit-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--accent);
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ── Shared close button ── */
.auth-modal-close,
.de-close,
.ne-close,
.wf-edit-close {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  color: var(--dim);
  width: 30px;
  height: 30px;
  border-radius: 8px;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
  line-height: 1;
  padding: 0;
}
.auth-modal-close:hover,
.de-close:hover,
.ne-close:hover,
.wf-edit-close:hover {
  border-color: var(--red);
  color: var(--red);
  background: rgba(239,68,68,0.1);
}

/* ── Shared body ── */
.auth-modal-body,
.de-form,
.wf-edit-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
}
.ne-body {
  flex: 1;
  overflow-y: auto;
  padding: 14px 16px;
}

/* ── Shared footer ── */
.de-footer,
.wf-edit-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 14px 20px;
  border-top: 1px solid var(--border);
  background: var(--bg-base);
}

/* ═══ Auth-specific (login/register) ═══ */
.auth-field { margin-bottom: 14px; }
.auth-field label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--dim);
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.auth-input {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-deep);
  color: var(--text);
  font-size: 14px;
  outline: none;
  box-sizing: border-box;
  transition: border-color .15s, box-shadow .15s;
}
.auth-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px var(--accent-glow);
}
.auth-error {
  color: var(--red);
  font-size: 12px;
  padding: 6px 0;
}
.auth-submit { width: 100%; margin-top: 8px; }
.auth-switch {
  text-align: center;
  margin-top: 16px;
  font-size: 12px;
  color: var(--dim);
}
.auth-switch a {
  color: var(--accent);
  text-decoration: none;
  cursor: pointer;
  font-weight: 600;
}
.auth-switch a:hover { text-decoration: underline; }

/* ═══ Device editor specific ═══ */
.de-section {
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}
.de-section:last-child { border-bottom: none; }
.de-section-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 12px;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.de-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.de-label {
  width: 90px;
  flex-shrink: 0;
  font-size: 12px;
  color: var(--dim);
  text-align: right;
  font-weight: 600;
}
.de-input {
  flex: 1;
  padding: 8px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-deep);
  color: var(--text);
  font-size: 13px;
  outline: none;
  font-family: var(--font-sans);
  transition: border-color .15s;
}
.de-input:focus { border-color: var(--accent); }
.de-input-sm { max-width: 100px; }
.de-input::placeholder { color: var(--dim); }
.de-hint {
  font-size: 11px;
  color: var(--dim);
  padding: 2px 0 0 100px;
  margin-top: -4px;
  margin-bottom: 6px;
}
.de-hint code {
  background: rgba(255,255,255,.08);
  padding: 1px 5px;
  border-radius: 3px;
  font-size: 11px;
}
.de-inst-list { display: flex; flex-wrap: wrap; gap: 6px; }
.de-inst-tag {
  background: rgba(245,158,11,.15);
  color: var(--accent);
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-family: var(--font-mono);
}
.de-footer { display: flex; justify-content: flex-end; gap: 8px; padding: 14px 20px; border-top: 1px solid var(--border); background: var(--bg-base); }

/* ═══ Workflow Editor specific ═══ */
.wf-edit-row { margin-bottom: 16px; }
.wf-edit-row label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: var(--dim);
  margin-bottom: 5px;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.wf-edit-row input[type="text"] {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-deep);
  color: var(--text);
  font-size: 13px;
  outline: none;
  box-sizing: border-box;
  transition: border-color .15s;
}
.wf-edit-row input[type="text"]:focus { border-color: var(--accent); }
.wf-edit-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px; }
.wf-edit-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border-radius: 6px;
  font-size: 11px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-secondary);
}
.wf-edit-tag-remove {
  cursor: pointer;
  color: var(--dim);
  font-size: 14px;
  line-height: 1;
  opacity: .5;
  transition: opacity .1s;
  border: none;
  background: none;
  padding: 0;
}
.wf-edit-tag-remove:hover { opacity: 1; color: var(--red); }
.wf-edit-tag-add {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}
.wf-edit-tag-add input[type="text"] {
  flex: 1;
  padding: 6px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-deep);
  color: var(--text);
  font-size: 12px;
  outline: none;
  transition: border-color .15s;
}
.wf-edit-tag-add input[type="text"]:focus { border-color: var(--accent); }

.wf-edit-thumb {
  width: 100%;
  min-height: 120px;
  border: 2px dashed var(--border);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  overflow: hidden;
  transition: border-color .15s, background .15s;
  background: var(--bg-deep);
}
.wf-edit-thumb:hover {
  border-color: var(--accent);
  background: rgba(245,158,11,.06);
}
.wf-edit-thumb img {
  max-width: 100%;
  max-height: 180px;
  object-fit: contain;
}
.wf-edit-thumb-placeholder {
  color: var(--dim);
  font-size: 13px;
}

/* ── Version management ── */
.wf-edit-version-upload {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}
.wf-edit-version-hint {
  font-size: 11px;
  color: var(--dim);
}
.wf-edit-version-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
  max-height: 200px;
  overflow-y: auto;
}
.wf-edit-version-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px;
  border-radius: 6px;
  background: var(--bg-deep);
  border: 1px solid var(--border);
  font-size: 12px;
  font-family: var(--font-mono);
}
.wf-edit-version-item:hover { border-color: var(--accent); }
.wf-edit-version-name {
  flex: 1;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.wf-edit-version-ts {
  font-size: 11px;
  color: var(--dim);
}
.wf-edit-version-del {
  width: 22px; height: 22px;
  border-radius: 4px;
  background: transparent;
  border: 1px solid transparent;
  color: var(--dim);
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
}
.wf-edit-version-del:hover {
  border-color: var(--red);
  color: var(--red);
  background: rgba(239,68,68,.08);
}

/* ═══ Node Editor specific ═══ */
.ne-instructions {
  font-size: 11px;
  color: var(--dim);
  margin-bottom: 12px;
  padding: 8px;
  background: var(--bg-base);
  border-radius: var(--radius);
  border: 1px solid var(--border);
}
.ne-instructions svg { vertical-align: middle; }
.ne-zones { display: flex; flex-direction: column; gap: 10px; }
.ne-zone {
  background: var(--bg-base);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: border-color .15s;
}
.ne-zone:hover { border-color: var(--border-hover); }
.ne-zone-title {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 12px;
  font-size: 12px;
  font-weight: 700;
  color: var(--accent);
  border-bottom: 1px solid var(--border);
  text-transform: uppercase;
  letter-spacing: .5px;
}
.ne-zone-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: 8px;
  min-height: 40px;
}
.ne-card-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  border-radius: var(--radius);
  background: var(--bg-card);
  border: 1px solid var(--border);
  font-size: 12px;
  color: var(--text-secondary);
  cursor: grab;
  transition: border-color .15s;
  user-select: none;
}
.ne-card-item:hover { border-color: var(--accent); }
.ne-card-item:active { cursor: grabbing; }

/* ── Delete old auth-specific that now inherits from shared base — no longer needed */
